Adapt to Boost >= 1.86 where sha1::get_digest() changed from taking
unsigned char* to unsigned int (&)[5] (digest_type).

--- a/src/util/hash/hash.cpp
+++ b/src/util/hash/hash.cpp
@@ -13,5 +13,12 @@ void Sha1_Compute(const char *value, size_t len, Sha1* output) {
   boost::uuids::detail::sha1 sha1;
   sha1.process_bytes(value, len);
-  sha1.get_digest(output->hash);
+  boost::uuids::detail::sha1::digest_type digest;
+  sha1.get_digest(digest);
+  for (int i = 0; i < 5; i++) {
+    output->hash[i*4]   = (digest[i] >> 24) & 0xFF;
+    output->hash[i*4+1] = (digest[i] >> 16) & 0xFF;
+    output->hash[i*4+2] = (digest[i] >> 8) & 0xFF;
+    output->hash[i*4+3] = digest[i] & 0xFF;
+  }
 }
 
