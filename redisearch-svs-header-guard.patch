Guard SVS include behind HAVE_SVS so the build succeeds without the SVS library.
VectorSimilarity includes the header unconditionally even when SVS is disabled.

--- a/deps/VectorSimilarity/src/VecSim/index_factories/tiered_factory.h
+++ b/deps/VectorSimilarity/src/VecSim/index_factories/tiered_factory.h
@@ -13,7 +13,9 @@
 #include "VecSim/memory/vecsim_malloc.h"
 #include "VecSim/vec_sim_index.h"
 #include "VecSim/algorithms/hnsw/hnsw_tiered.h"
-#include "VecSim/algorithms/svs/svs_tiered.h"
+#if HAVE_SVS
+#include "VecSim/algorithms/svs/svs_tiered.h"
+#endif
 #include "VecSim/algorithms/brute_force/brute_force.h"
 #include "VecSim/index_factories/factory_utils.h"
 
